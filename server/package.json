{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsc-watch --preserveWatchOutput --onSuccess \"node --enable-source-maps dist/index.js\"",
    "docker:dev": "docker compose up --build app",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "db:logs": "docker compose logs -f db",
    "typeorm": "typeorm-ts-node-esm",
    "db:generate": "typeorm-ts-node-esm migration:generate -d src/db/data-source.ts",
    "db:create": "typeorm-ts-node-esm migration:create",
    "db:migrate": "typeorm-ts-node-esm migration:run -d src/db/data-source.ts",
    "db:revert": "typeorm-ts-node-esm migration:revert -d src/db/data-source.ts",
    "db:show": "typeorm-ts-node-esm migration:show -d src/db/data-source.ts",
    "seed": "tsx src/db/seed.ts",
    "db:migrate:prod": "typeorm migration:run -d dist/db/data-source.js",
    "db:revert:prod": "typeorm migration:revert -d dist/db/data-source.js",
    "db:show:prod": "typeorm migration:show -d dist/db/data-source.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "graphql-scalars": "^1.25.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@apollo/server": "^4",
    "@as-integrations/express5": "^1.1.2",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "2.0.0-rc.3",
    "typeorm": "^0.3"
  }
}
