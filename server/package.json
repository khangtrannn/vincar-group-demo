{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",

    "docker:dev": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "db:logs": "docker compose logs -f db",

    "typeorm": "typeorm -d dist/db/data-source.js",
    "migration:generate": "pnpm build && pnpm typeorm migration:generate",
    "migration:run": "pnpm build && pnpm typeorm migration:run",
    "migration:revert": "pnpm build && pnpm typeorm migration:revert",
    "migration:show": "pnpm build && pnpm typeorm migration:show"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  }
}
